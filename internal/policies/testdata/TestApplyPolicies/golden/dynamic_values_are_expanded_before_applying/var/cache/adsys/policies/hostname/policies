gpos:
    - id: '{GPOId}'
      name: GPOName
      rules:
        dconf:
            - key: path/to/key
              value: '''value for ${DOMAIN}'''
              disabled: false
              meta: s
        mount:
            - key: system-mounts
              value: |
                nfs://${DOMAIN}/nfs_share
                smb://server/${DOMAIN}/data
              disabled: false
